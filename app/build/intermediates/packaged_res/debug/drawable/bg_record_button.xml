<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="50%"
                android:startColor="#FF8C4FFF"
                android:endColor="#FF5B2ECC" />
            <corners android:radius="100dp" />
            <stroke android:width="2dp" android:color="#AAFFFFFF" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="50%"
                android:startColor="#FF7B3FEF"
                android:endColor="#FF4A22AA" />
            <corners android:radius="100dp" />
            <stroke android:width="1.5dp" android:color="#66FFFFFF" />
        </shape>
    </item>
</selector>
