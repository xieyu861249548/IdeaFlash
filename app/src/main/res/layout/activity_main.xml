<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ══════════════════════════════════════════
         MAIN CONTENT
    ══════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- TOP: App Name Header -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="36dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 标题区域（左对齐） -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="start">

                <TextView
                    android:id="@+id/tvAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="#FFFFFFFF"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:gravity="start"
                    android:shadowColor="#44000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="4" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/subtitle"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:gravity="start"
                    android:layout_marginTop="4dp" />

                <!-- 无障碍引导提示：未开启时显示 -->
                <TextView
                    android:id="@+id/btnEnableAccessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ 开启三击音量键快速录音"
                    android:textColor="#AAFFFFFF"
                    android:textSize="11sp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:background="@drawable/bg_manual_btn"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- 汉堡菜单图标（右上角，顶对齐） -->
            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top"
                android:src="@drawable/ic_menu"
                android:padding="6dp"
                android:tint="#AAFFFFFF"
                android:background="@drawable/bg_action_btn"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="菜单" />

        </LinearLayout>

        <!-- 激活态蒙层（长按时显示，点击退出激活态） — must be BEFORE ViewPager so ViewPager draws on top -->
        <View
            android:id="@+id/dimOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#CC000000"
            android:alpha="0"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- MIDDLE: Card Carousel -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            app:layout_constraintBottom_toTopOf="@id/bottomSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="48dp"
            android:clipToPadding="false"
            android:clipChildren="false" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            app:layout_constraintBottom_toTopOf="@id/bottomSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_empty_capsule"
                android:contentDescription="空状态图标" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="按住下方按钮\n开始录制灵感"
                android:textColor="#CCFFFFFF"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

        <!-- BOTTOM: Combined Action Bar Section -->
        <LinearLayout
            android:id="@+id/bottomSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="40dp"
            android:paddingTop="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Dots Indicator -->
            <LinearLayout
                android:id="@+id/dotsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="14dp" />

            <!-- 小状态提示行（AI 处理中） -->
            <LinearLayout
                android:id="@+id/processingHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="10dp">

                <ProgressBar
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:indeterminate="true"
                    android:indeterminateTint="#AAFFFFFF" />

                <TextView
                    android:id="@+id/tvLoading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI 正在生成文案…"
                    android:textColor="#AAFFFFFF"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

            <!-- Recording wave animation -->
            <View
                android:id="@+id/recordingWave"
                android:layout_width="80dp"
                android:layout_height="4dp"
                android:background="@drawable/bg_wave"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <!-- Combined Pill: 录音 | 手动记录 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:layout_marginHorizontal="84dp"
                android:background="@drawable/bg_bottom_action_bar">

                <!-- Left: Record Section -->
                <LinearLayout
                    android:id="@+id/btnRecordSection"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvRecordHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点击录音"
                        android:textColor="#CCFFFFFF"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical"
                    android:background="#44FFFFFF" />

                <!-- Right: Manual Section -->
                <LinearLayout
                    android:id="@+id/btnManualSection"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/btnManualAdd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="手动记录"
                        android:textColor="#CCFFFFFF"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- 激活态：完成按钮（绿色胶囊，顶部居中） -->
        <TextView
            android:id="@+id/activatedCompleteBtn"
            android:layout_width="120dp"
            android:layout_height="44dp"
            android:text="✓ 完成"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:background="@drawable/bg_pill_green_selector"
            android:elevation="6dp"
            android:stateListAnimator="@null"
            android:visibility="gone"
            android:alpha="0"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="50dp" />

        <!-- 激活态：操作行（浮窗 / 编辑 / 原文，椭圆 pill 按钮，卡片下方） -->
        <LinearLayout
            android:id="@+id/activatedActionsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/activatedCompleteBtn"
            app:layout_constraintBottom_toTopOf="@id/activatedDiscardBtn"
            app:layout_constraintVertical_bias="0.78">

            <!-- 浮窗 -->
            <TextView
                android:id="@+id/btnActivatedFloat"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="浮窗"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:gravity="center"
                android:paddingHorizontal="22dp"
                android:background="@drawable/bg_pill_glass_selector"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginHorizontal="6dp" />

            <!-- 编辑 -->
            <TextView
                android:id="@+id/btnActivatedEdit"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="编辑"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:gravity="center"
                android:paddingHorizontal="22dp"
                android:background="@drawable/bg_pill_glass_selector"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginHorizontal="6dp" />

            <!-- 原文 -->
            <TextView
                android:id="@+id/btnActivatedTranscript"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="原文"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:gravity="center"
                android:paddingHorizontal="22dp"
                android:background="@drawable/bg_pill_glass_selector"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginHorizontal="6dp" />

        </LinearLayout>

        <!-- 激活态：丢弃按钮（红色胶囊，底部居中） -->
        <TextView
            android:id="@+id/activatedDiscardBtn"
            android:layout_width="120dp"
            android:layout_height="44dp"
            android:text="✕ 丢弃"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:background="@drawable/bg_pill_red_selector"
            android:elevation="6dp"
            android:stateListAnimator="@null"
            android:visibility="gone"
            android:alpha="0"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="50dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ══════════════════════════════════════════
         DRAWER PANEL (以往灵感)
    ══════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/drawerContainer"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient"
        android:layout_gravity="end" />

</androidx.drawerlayout.widget.DrawerLayout>
